rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    
    // Hardened Admin Check: Checks specific emails and verified status
    function isAdmin() { 
      return isSignedIn() && 
             (request.auth.token.email == 'computercorner@gmail.com' || 
              request.auth.token.email == 'sabujdas5757@gmail.com');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // Validation Blueprints
    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'img']) && 
             data.name is string &&
             data.img is string;
    }

    function isValidBrand(data) {
      return data.keys().hasAll(['name']) && 
             data.name is string;
    }

    function isValidPromoBanner(data) {
      return data.keys().hasAll(['image', 'order']) &&
             data.image is string &&
             data.order is number;
    }

    function isValidSetting(data) {
      return true; // We can make it more specific if needed, but for now just allow admins
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 &&
             data.brand is string &&
             data.category is string &&
             data.price is string &&
             data.image is string;
    }

    function isValidVariousFilter(data) {
      return data.name is string && data.name.size() > 0;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBrand(incoming());
      allow delete: if isAdmin();
    }

    match /various_filters/{filterId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidVariousFilter(incoming());
      allow delete: if isAdmin();
    }

    match /promoBanners/{bannerId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPromoBanner(incoming());
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }
  }
}
