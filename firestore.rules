rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
             (request.auth.token.email == 'computercorner@gmail.com' || request.auth.token.email == 'sabujdas5757@gmail.com'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'img']) && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.img is string && data.img.size() > 0 && data.img.size() <= 500 &&
             (data.keys().size() == 2 || 
              (data.keys().size() == 3 && (data.keys().hasAny(['createdAt', 'updatedAt']))) ||
              (data.keys().size() == 4 && data.keys().hasAll(['createdAt', 'updatedAt'])));
    }

    function isValidBrand(data) {
      return data.keys().hasAll(['name']) && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (data.keys().size() <= 4); // name, img, createdAt, updatedAt
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBrand(incoming());
      allow update: if isAdmin() && isValidBrand(incoming());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
