{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product category for the category grid and featured sections on the home page",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "img": { "type": "string" },
        "showAsSection": { "type": "boolean" },
        "sectionTitle": { "type": "string" },
        "sectionOrder": { "type": "number" }
      },
      "required": ["name", "img"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Product brand",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "img": { "type": "string" }
      },
      "required": ["name"]
    },
    "PromoBanner": {
      "title": "Promo Banner",
      "description": "Customizable promotional banners for the home page",
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "link": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["image", "order"]
    },
    "Product": {
      "title": "Product",
      "description": "Hardware product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "oldPrice": { "type": "string" },
        "discount": { "type": "string" },
        "usageTags": { "type": "array", "items": { "type": "string" } },
        "isHotSelling": { "type": "boolean" },
        "showInHomeGrid": { "type": "boolean" },
        "image": { "type": "string" },
        "additionalImages": { "type": "array", "items": { "type": "string" } },
        "specifications": { "type": "object" }
      },
      "required": ["name", "brand", "category", "price", "image"]
    },
    "VariousFilter": {
      "title": "Various Filter",
      "description": "Customizable filters for the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "categories": {
      "schema": "Category",
      "description": "Categories for navigation and home page grid"
    },
    "brands": {
      "schema": "Brand",
      "description": "Available product brands"
    },
    "promoBanners": {
      "schema": "PromoBanner",
      "description": "Promotional banners for home page"
    },
    "products": {
      "schema": "Product",
      "description": "Main product catalog"
    },
    "various_filters": {
      "schema": "VariousFilter",
      "description": "Custom filters for catalog filtering"
    }
  }
}
