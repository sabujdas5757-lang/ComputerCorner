rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    
    // Hardened Admin Check: Checks specific admins collection (consistent with AdminRoute)
    function isAdmin() { 
      return isSignedIn() && 
             (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
              request.auth.token.email.matches('(?i)computercorner15@yahoo.com') || 
              request.auth.token.email.matches('(?i)sabujdas5757@gmail.com'));
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'img']) && 
             data.name is string &&
             data.img is string;
    }

    function isValidBrand(data) {
      return data.keys().hasAll(['name']) && 
             data.name is string;
    }

    function isValidBanner(data) {
      return data.keys().hasAll(['image', 'order']) &&
             data.image is string &&
             data.order is number;
    }

    function isValidSetting(data) {
      return true; // We can make it more specific if needed, but for now just allow admins
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 &&
             data.brand is string &&
             data.category is string &&
             data.price is string &&
             data.image is string;
    }

    function isValidVariousFilter(data) {
      return data.name is string && data.name.size() > 0;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBrand(incoming());
      allow delete: if isAdmin();
    }

    match /various_filters/{filterId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidVariousFilter(incoming());
      allow delete: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBanner(incoming());
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usageHubs/{hubId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'rating', 'comment']) &&
             data.productId is string &&
             data.userId == request.auth.uid &&
             data.rating is number &&
             data.rating >= 1 && data.rating <= 5 &&
             data.comment is string;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['firstName', 'phone', 'cartTotal', 'transactionId', 'userId', 'createdAt', 'status']) &&
             data.firstName is string &&
             data.phone is string &&
             data.cartTotal is number &&
             data.transactionId is string &&
             data.status in ['pending', 'confirmed', 'shipping', 'shipped', 'delivered', 'cancelled', 'cancellation requested'];
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (
        isSignedIn() && 
        existing().userId == request.auth.uid && 
        (incoming().status == 'cancelled' || incoming().status == 'cancellation requested') &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'cancelledAt', 'cancellationReason']) &&
        (existing().createdAt == null || (request.time < existing().createdAt + duration.value(24, 'h')))
      );
      allow delete: if isAdmin();
    }
  }
}
