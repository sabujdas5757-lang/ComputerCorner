{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product category for the category grid and featured sections on the home page",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "img": { "type": "string" },
        "showAsSection": { "type": "boolean" },
        "sectionTitle": { "type": "string" },
        "sectionOrder": { "type": "number" }
      },
      "required": ["name", "img"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Product brand",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "img": { "type": "string" }
      },
      "required": ["name"]
    },
    "Banner": {
      "title": "Home Banner",
      "description": "Customizable hero banners/ads for the top of the home page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["image", "order"]
    },
    "Product": {
      "title": "Product",
      "description": "Hardware product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "oldPrice": { "type": "string" },
        "discount": { "type": "string" },
        "usageTags": { "type": "array", "items": { "type": "string" } },
        "isHotSelling": { "type": "boolean" },
        "showInHomeGrid": { "type": "boolean" },
        "image": { "type": "string" },
        "additionalImages": { "type": "array", "items": { "type": "string" } },
        "specifications": { "type": "object" }
      },
      "required": ["name", "brand", "category", "price", "image"]
    },
    "VariousFilter": {
      "title": "Various Filter",
      "description": "Customizable filters for the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "User checkout order",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "houseNumber": { "type": "string" },
        "streetAddress": { "type": "string" },
        "city": { "type": "string" },
        "zipCode": { "type": "string" },
        "userId": { "type": "string" },
        "transactionId": { "type": "string" },
        "cartTotal": { "type": "number" },
        "items": { "type": "array" }
      },
      "required": ["firstName", "phone", "cartTotal", "transactionId"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review left by a user who ordered the product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    }
  },
  "firestore": {
    "reviews": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders from checkout"
    },
    "categories": {
      "schema": "Category",
      "description": "Categories for navigation and home page grid"
    },
    "brands": {
      "schema": "Brand",
      "description": "Available product brands"
    },
    "banners": {
      "schema": "Banner",
      "description": "Hero banners/ads for home page top"
    },
    "products": {
      "schema": "Product",
      "description": "Main product catalog"
    },
    "various_filters": {
      "schema": "VariousFilter",
      "description": "Custom filters for catalog filtering"
    }
  }
}
